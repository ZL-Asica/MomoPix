{
  "name": "momo-pix",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "deploy": "pnpm run lint:fix && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "pnpm run lint:fix && opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings ./cloudflare-env.d.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@auth/d1-adapter": "^1.9.1",
    "@jsquash/avif": "^2.1.0",
    "@jsquash/jpeg": "^1.6.0",
    "@jsquash/oxipng": "^2.3.0",
    "@jsquash/webp": "^1.5.0",
    "@marsidev/react-turnstile": "^1.3.1",
    "@opennextjs/cloudflare": "^1.0.3",
    "@prisma/adapter-d1": "^6.8.2",
    "@prisma/client": "^6.8.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@zl-asica/react": "^0.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.553.0",
    "next": "15.3.2",
    "next-auth": "5.0.0-beta.28",
    "prisma": "^6.8.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^14.3.8",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^6.2.0",
    "@changesets/cli": "^2.29.7",
    "@eslint-react/eslint-plugin": "^2.3.1",
    "@eslint/eslintrc": "^3",
    "@next/eslint-plugin-next": "^16.0.1",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^24.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.1",
    "eslint-plugin-format": "^1.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.46.0"
  },
  "lint-staged": {
    "**/*.{md,mdx}": [
      "prettier --write"
    ],
    "**/*.{js,jsx,ts,tsx,json,css,scss,less,styl,html,yml,mdx}": [
      "eslint --fix"
    ]
  },
  "prettier": {
    "semi": false,
    "singleQuote": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "last 2 versions",
      "not dead",
      "no op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
